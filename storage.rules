rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public images - Read access for everyone, write for admins
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Public icons - Read access for everyone, write for admins
    match /icons/{iconId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Public store logos - Read access for everyone, write for admins
    match /logos/{logoId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Blog post images - Read access for everyone, write for admins
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Event banners - Read access for everyone, write for admins
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // User uploaded content (if needed in future)
    match /uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
