# ===========================================
# ARABIC COUPON PLATFORM - ENVIRONMENT CONFIG
# ===========================================

# Application
APP_NAME="Arabic Coupon Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.9797.coupons

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=coupons
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0

# Firebase
FIREBASE_PROJECT_ID=x9797x707x
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY_ID=""

# API Security
API_TOKEN=your_super_secure_api_token_here

# OpenAI (for voice assistant)
OPENAI_API_KEY=your_openai_api_key_here

# Blockchain (Ethereum)
WEB3_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
ETH_PRIVATE_KEY=your_ethereum_private_key
COUPON_CONTRACT_ADDRESS=0x...

# Social Media APIs
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# Payment Gateways
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Email Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="Arabic Coupons"

# SMS/Notifications
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=+1234567890

# Analytics & Monitoring
MIXPANEL_TOKEN=your_mixpanel_token
AMPLITUDE_API_KEY=your_amplitude_key
SENTRY_DSN=your_sentry_dsn
GRAFANA_PASSWORD=admin

# File Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=coupons-uploads
AWS_USE_PATH_STYLE_ENDPOINT=false

# Security
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_32_character_encryption_key

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=arabic_coupons
CACHE_TTL=3600

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Queue Configuration
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=redis

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_STACK=daily

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=true
ERROR_TRACKING_ENABLED=true
ANALYTICS_ENABLED=true

# Feature Flags
FEATURE_AR_ENABLED=true
FEATURE_VOICE_ENABLED=true
FEATURE_SOCIAL_ENABLED=true
FEATURE_BLOCKCHAIN_ENABLED=true
FEATURE_GAMIFICATION_ENABLED=true
FEATURE_AI_RECOMMENDATIONS=true

# Third-party Services
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_API_KEY=your_algolia_api_key
SENDGRID_API_KEY=your_sendgrid_api_key
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_key

# Mobile App Configuration
APP_STORE_URL=https://apps.apple.com/app/arabic-coupons/id123456789
GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.arabic.coupons

# Admin Configuration
ADMIN_EMAIL=admin@9797.coupons
ADMIN_PASSWORD=your_secure_admin_password

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30

# CDN Configuration
CDN_ENABLED=true
CDN_URL=https://cdn.9797.coupons
CDN_KEY=your_cdn_key
CDN_SECRET=your_cdn_secret

# Webhook Endpoints
WEBHOOK_COUPON_CREATED=https://api.partner.com/webhooks/coupon-created
WEBHOOK_USER_REGISTERED=https://api.partner.com/webhooks/user-registered
WEBHOOK_PURCHASE_COMPLETED=https://api.partner.com/webhooks/purchase-completed

# Development
DEBUG_BAR_ENABLED=false
TELESCOPE_ENABLED=false
HORIZON_ENABLED=false
