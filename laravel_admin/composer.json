{
    "name": "arabic-coupon/admin",
    "type": "project",
    "description": "Laravel admin backend for Arabic coupon aggregator",
    "keywords": ["laravel", "coupons", "arabic", "admin"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "laravel/horizon": "^5.15",
        "laravel/octane": "^2.0",
        "laravel/scout": "^10.0",
        "laravel/cashier": "^15.0",
        "laravel/spark": "^4.0",
        "league/csv": "^9.10",
        "intervention/image": "^3.0",
        "guzzlehttp/guzzle": "^7.8",
        "spatie/laravel-activitylog": "^4.7",
        "maatwebsite/excel": "^3.1",
        "google/cloud-firestore": "^1.21",
        "predis/predis": "^2.2",
        "meilisearch/meilisearch-php": "^1.0",
        "elasticsearch/elasticsearch": "^8.0",
        "mongodb/mongodb": "^1.16",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/flysystem-google-cloud-storage": "^2.0",
        "spatie/laravel-backup": "^8.0",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-query-builder": "^5.0",
        "spatie/laravel-fractal": "^6.0",
        "barryvdh/laravel-debugbar": "^3.8",
        "barryvdh/laravel-ide-helper": "^3.0",
        "beyondcode/laravel-websockets": "^1.14",
        "pusher/pusher-php-server": "^7.2",
        "laravel/socialite": "^5.6",
        "laravel/passport": "^12.0",
        "tymon/jwt-auth": "^2.0",
        "spatie/laravel-cors": "^3.0",
        "fruitcake/laravel-cors": "^3.0",
        "spatie/laravel-responsecache": "^7.4",
        "spatie/laravel-schemaless-attributes": "^2.4",
        "spatie/laravel-tags": "^4.3",
        "spatie/laravel-sluggable": "^3.4",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-image-optimizer": "^1.7",
        "spatie/laravel-analytics": "^5.0",
        "spatie/laravel-dashboard": "^3.0",
        "spatie/laravel-sitemap": "^7.0",
        "spatie/laravel-feed": "^4.2",
        "spatie/laravel-newsletter": "^5.0",
        "spatie/laravel-cookie-consent": "^3.2",
        "spatie/laravel-honeypot": "^4.3",
        "spatie/laravel-ray": "^1.32",
        "spatie/laravel-schedule-monitor": "^3.1",
        "spatie/laravel-health": "^1.24",
        "spatie/laravel-ignition": "^2.3",
        "nunomaduro/collision": "^8.0",
        "nunomaduro/termwind": "^1.15",
        "livewire/livewire": "^3.0",
        "filament/filament": "^3.0",
        "inertiajs/inertia-laravel": "^1.0",
        "tightenco/ziggy": "^2.0",
        "mezzio/mezzio": "^3.17",
        "laminas/laminas-component-installer": "^3.3",
        "symfony/mailer": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/cache": "^7.0",
        "doctrine/dbal": "^4.0",
        "ramsey/uuid": "^4.7",
        "carbon/carbon": "^3.0",
        "nesbot/carbon": "^3.0",
        "jenssegers/agent": "^2.6",
        "geoip2/geoip2": "^3.0",
        "torann/geoip": "^3.0",
        "laravel-notification-channels/webhook": "^3.0",
        "laravel-notification-channels/twilio": "^3.2",
        "laravel-notification-channels/discord": "^1.4",
        "laravel-notification-channels/telegram": "^4.0",
        "laravel-notification-channels/slack": "^2.1",
        "laravel-notification-channels/fcm": "^3.0",
        "laravel-notification-channels/onesignal": "^2.3",
        "webmozart/assert": "^1.11",
        "psr/log": "^3.0",
        "monolog/monolog": "^3.0",
        "rollbar/rollbar": "^4.0",
        "sentry/sentry-laravel": "^4.0",
        "bugsnag/bugsnag-laravel": "^2.26",
        "laravel/dusk": "^8.0",
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
